<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.app.mapper.AdminMapper">

    <resultMap id="adminResultMap" type="com.example.app.domain.Admin">
        <result property="loginId" column="login_id" />
        <result property="loginPass" column="login_pass" />
    </resultMap>

    <select id="selectByLoginId" resultMap="adminResultMap">
        SELECT
            login_id,
            login_pass
        FROM admins
        WHERE login_id = #{loginId}
    </select>

</mapper>